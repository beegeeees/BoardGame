<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="#E8F5E9"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="불편마불 보드판"
        android:textSize="32sp"
        android:textStyle="bold"
        android:textColor="#2E7D32"
        android:layout_marginBottom="50dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="20dp">

            <Button
                android:id="@+id/btnStartPasswordGame"
                android:layout_width="200dp"
                android:layout_height="80dp"
                android:text="미니게임 2\n(비밀번호 설정)"
                android:textSize="18sp"
                android:layout_marginEnd="20dp"
                android:backgroundTint="#1976D2"/>

            <Button
                android:id="@+id/btnStartAdGame1"
                android:layout_width="200dp"
                android:layout_height="80dp"
                android:text="광고 게임 1\n(진짜 X 찾기)"
                android:textSize="18sp"
                android:backgroundTint="#FBC02D"
                android:textColor="#000000"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnStartAdGame2"
                android:layout_width="200dp"
                android:layout_height="80dp"
                android:text="광고 게임 2\n(시간 맞추기)"
                android:textSize="18sp"
                android:layout_marginEnd="20dp"
                android:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"/>

            <Button
                android:id="@+id/btnStartAdGame3"
                android:layout_width="200dp"
                android:layout_height="80dp"
                android:text="광고 게임 3\n(빠른 연타)"
                android:textSize="18sp"
                android:backgroundTint="#E53935"
                android:textColor="#FFFFFF"/>
        </LinearLayout>

        <Button
            android:id="@+id/btnStartDiceGame"
            android:layout_width="420dp"
            android:layout_height="80dp"
            android:layout_marginTop="20dp"
            android:text="주사위 굴리기"
            android:textSize="22sp"
            android:textStyle="bold"
            android:backgroundTint="#673AB7"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

</LinearLayout>