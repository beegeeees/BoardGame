<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/board_green"
    android:padding="@dimen/board_screen_padding">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/boardArea"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_board_surface"
        android:elevation="2dp"
        android:padding="@dimen/board_surface_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_percent="0.92"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintWidth_percent="0.76">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/g_v1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.2" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/g_v2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.4" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/g_v3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.6" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/g_v4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.8" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/g_h1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.2" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/g_h2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.4" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/g_h3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.6" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/g_h4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            app:layout_constraintGuide_percent="0.8" />

        <TextView
            android:id="@+id/tile0"
            style="@style/BoardTile"
            android:text="시작"
            app:layout_constraintBottom_toTopOf="@id/g_h1"
            app:layout_constraintEnd_toEndOf="@id/g_v1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tile1"
            style="@style/BoardTile"
            android:text="점수 +"
            app:layout_constraintBottom_toTopOf="@id/g_h1"
            app:layout_constraintEnd_toEndOf="@id/g_v2"
            app:layout_constraintStart_toEndOf="@id/g_v1"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tile2"
            style="@style/BoardTile"
            android:text="카드"
            app:layout_constraintBottom_toTopOf="@id/g_h1"
            app:layout_constraintEnd_toEndOf="@id/g_v3"
            app:layout_constraintStart_toEndOf="@id/g_v2"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tile3"
            style="@style/BoardTile"
            android:text="점수 +"
            app:layout_constraintBottom_toTopOf="@id/g_h1"
            app:layout_constraintEnd_toEndOf="@id/g_v4"
            app:layout_constraintStart_toEndOf="@id/g_v3"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tile4"
            style="@style/BoardTile"
            android:text="?"
            app:layout_constraintBottom_toTopOf="@id/g_h1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/g_v4"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tile5"
            style="@style/BoardTile"
            android:text="점수 +"
            app:layout_constraintBottom_toTopOf="@id/g_h2"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/g_v4"
            app:layout_constraintTop_toBottomOf="@id/g_h1" />

        <TextView
            android:id="@+id/tile6"
            style="@style/BoardTile"
            android:text="광고"
            app:layout_constraintBottom_toTopOf="@id/g_h3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/g_v4"
            app:layout_constraintTop_toBottomOf="@id/g_h2" />

        <TextView
            android:id="@+id/tile7"
            style="@style/BoardTile"
            android:text="점수 -"
            app:layout_constraintBottom_toTopOf="@id/g_h4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/g_v4"
            app:layout_constraintTop_toBottomOf="@id/g_h3" />

        <TextView
            android:id="@+id/tile8"
            style="@style/BoardTile"
            android:text="?"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/g_v4"
            app:layout_constraintTop_toBottomOf="@id/g_h4" />

        <TextView
            android:id="@+id/tile9"
            style="@style/BoardTile"
            android:text="점수 -"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/g_v4"
            app:layout_constraintStart_toEndOf="@id/g_v3"
            app:layout_constraintTop_toBottomOf="@id/g_h4" />

        <TextView
            android:id="@+id/tile10"
            style="@style/BoardTile"
            android:text="카드"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/g_v3"
            app:layout_constraintStart_toEndOf="@id/g_v2"
            app:layout_constraintTop_toBottomOf="@id/g_h4" />

        <TextView
            android:id="@+id/tile11"
            style="@style/BoardTile"
            android:text="점수 +"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/g_v2"
            app:layout_constraintStart_toEndOf="@id/g_v1"
            app:layout_constraintTop_toBottomOf="@id/g_h4" />

        <TextView
            android:id="@+id/tile12"
            style="@style/BoardTile"
            android:text="?"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@id/g_v1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/g_h4" />

        <TextView
            android:id="@+id/tile13"
            style="@style/BoardTile"
            android:text="점수 -"
            app:layout_constraintBottom_toTopOf="@id/g_h4"
            app:layout_constraintEnd_toEndOf="@id/g_v1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/g_h3" />

        <TextView
            android:id="@+id/tile14"
            style="@style/BoardTile"
            android:text="광고"
            app:layout_constraintBottom_toTopOf="@id/g_h3"
            app:layout_constraintEnd_toEndOf="@id/g_v1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/g_h2" />

        <TextView
            android:id="@+id/tile15"
            style="@style/BoardTile"
            android:text="점수 +"
            app:layout_constraintBottom_toTopOf="@id/g_h2"
            app:layout_constraintEnd_toEndOf="@id/g_v1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/g_h1" />

        <TextView
            android:id="@+id/txtDiceVisual"
            android:layout_width="@dimen/board_dice_size"
            android:layout_height="@dimen/board_dice_size"
            android:background="@drawable/dice_shape"
            android:elevation="4dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="?"
            android:textColor="#000000"
            android:textSize="@dimen/board_dice_text_size"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/btnDice"
            app:layout_constraintEnd_toEndOf="@id/g_v4"
            app:layout_constraintStart_toEndOf="@id/g_v1"
            app:layout_constraintTop_toBottomOf="@id/g_h1"
            app:layout_constraintVertical_chainStyle="packed" />

        <Button
            android:id="@+id/btnDice"
            android:layout_width="@dimen/board_roll_button_width"
            android:layout_height="@dimen/board_roll_button_height"
            android:layout_marginTop="6dp"
            android:layout_marginBottom="6dp"
            android:background="@drawable/bg_board_roll_button"
            android:backgroundTint="@null"
            android:elevation="5dp"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:minWidth="0dp"
            android:minHeight="0dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:text="주사위"
            android:textAllCaps="false"
            android:textColor="@color/white"
            android:textSize="@dimen/board_roll_button_text_size"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/txtDiceCountdown"
            app:layout_constraintEnd_toEndOf="@id/g_v4"
            app:layout_constraintStart_toEndOf="@id/g_v1"
            app:layout_constraintTop_toBottomOf="@id/txtDiceVisual" />

        <TextView
            android:id="@+id/txtDiceCountdown"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:text="주사위 선택 30초"
            android:textColor="#FFCA28"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            app:layout_constraintBottom_toTopOf="@id/txtTurnInfo"
            app:layout_constraintEnd_toEndOf="@id/g_v4"
            app:layout_constraintStart_toEndOf="@id/g_v1"
            app:layout_constraintTop_toBottomOf="@id/btnDice" />

        <TextView
            android:id="@+id/txtTurnInfo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:layout_marginEnd="6dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="3"
            android:ellipsize="end"
            android:textColor="#FFFFFF"
            android:textSize="@dimen/board_turn_text_size"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/g_h4"
            app:layout_constraintEnd_toEndOf="@id/g_v4"
            app:layout_constraintStart_toEndOf="@id/g_v1"
            app:layout_constraintTop_toBottomOf="@id/txtDiceCountdown" />

        <ImageView
            android:id="@+id/player1"
            android:layout_width="@dimen/board_player_token_size"
            android:layout_height="@dimen/board_player_token_size"
            android:elevation="10dp"
            android:src="@drawable/player_red"
            android:translationX="-8dp"
            android:translationY="-8dp"
            app:layout_constraintBottom_toBottomOf="@id/tile0"
            app:layout_constraintEnd_toEndOf="@id/tile0"
            app:layout_constraintStart_toStartOf="@id/tile0"
            app:layout_constraintTop_toTopOf="@id/tile0" />

        <ImageView
            android:id="@+id/player2"
            android:layout_width="@dimen/board_player_token_size"
            android:layout_height="@dimen/board_player_token_size"
            android:elevation="10dp"
            android:src="@drawable/player_blue"
            android:translationX="8dp"
            android:translationY="-8dp"
            app:layout_constraintBottom_toBottomOf="@id/tile0"
            app:layout_constraintEnd_toEndOf="@id/tile0"
            app:layout_constraintStart_toStartOf="@id/tile0"
            app:layout_constraintTop_toTopOf="@id/tile0" />

        <ImageView
            android:id="@+id/player3"
            android:layout_width="@dimen/board_player_token_size"
            android:layout_height="@dimen/board_player_token_size"
            android:elevation="10dp"
            android:src="@drawable/player_green"
            android:translationX="-8dp"
            android:translationY="8dp"
            app:layout_constraintBottom_toBottomOf="@id/tile0"
            app:layout_constraintEnd_toEndOf="@id/tile0"
            app:layout_constraintStart_toStartOf="@id/tile0"
            app:layout_constraintTop_toTopOf="@id/tile0" />

        <ImageView
            android:id="@+id/player4"
            android:layout_width="@dimen/board_player_token_size"
            android:layout_height="@dimen/board_player_token_size"
            android:elevation="10dp"
            android:src="@drawable/player_yellow"
            android:translationX="8dp"
            android:translationY="8dp"
            app:layout_constraintBottom_toBottomOf="@id/tile0"
            app:layout_constraintEnd_toEndOf="@id/tile0"
            app:layout_constraintStart_toStartOf="@id/tile0"
            app:layout_constraintTop_toTopOf="@id/tile0" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <FrameLayout
        android:id="@+id/diceOverlay"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="#99000000"
        android:clickable="true"
        android:elevation="30dp"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.cardview.widget.CardView
            android:layout_width="520dp"
            android:layout_height="330dp"
            android:layout_gravity="center"
            app:cardBackgroundColor="@android:color/white"
            app:cardCornerRadius="8dp"
            app:cardElevation="12dp">

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">

                <Button
                    android:id="@+id/diceOverlayBoardButton"
                    android:layout_width="94dp"
                    android:layout_height="38dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="12dp"
                    android:layout_marginEnd="12dp"
                    android:backgroundTint="#607D8B"
                    android:elevation="8dp"
                    android:includeFontPadding="false"
                    android:minHeight="0dp"
                    android:minWidth="0dp"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:text="보드 보기"
                    android:textAllCaps="false"
                    android:textColor="@android:color/white"
                    android:textSize="13sp"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/diceSelectionContent"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:clipChildren="false"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:padding="18dp">

                    <TextView
                        android:id="@+id/diceOverlayTimer"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="30"
                        android:textColor="#FFCA28"
                        android:textSize="38sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/diceOverlayInstruction"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:gravity="center"
                        android:maxLines="2"
                        android:text="주사위 버튼을 선택하고 굴리기를 누르세요."
                        android:textColor="#333333"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/diceOverlayVisual"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:includeFontPadding="false"
                        android:text="⚀"
                        android:textColor="#333333"
                        android:textSize="54sp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="58dp"
                        android:clipChildren="false"
                        android:orientation="horizontal"
                        android:weightSum="4">

                        <Button
                            android:id="@+id/diceOverlay12"
                            style="@style/Widget.AppCompat.Button"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginEnd="4dp"
                            android:layout_weight="1"
                            android:autoSizeMaxTextSize="13sp"
                            android:autoSizeMinTextSize="10sp"
                            android:autoSizeTextType="uniform"
                            android:backgroundTint="#42A5F5"
                            android:gravity="center"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:padding="2dp"
                            android:text="1~2\n(30%)"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/diceOverlay34"
                            style="@style/Widget.AppCompat.Button"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="4dp"
                            android:layout_weight="1"
                            android:autoSizeMaxTextSize="13sp"
                            android:autoSizeMinTextSize="10sp"
                            android:autoSizeTextType="uniform"
                            android:backgroundTint="#66BB6A"
                            android:gravity="center"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:padding="2dp"
                            android:text="3~4\n(20%)"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/diceOverlay56"
                            style="@style/Widget.AppCompat.Button"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginHorizontal="4dp"
                            android:layout_weight="1"
                            android:autoSizeMaxTextSize="13sp"
                            android:autoSizeMinTextSize="10sp"
                            android:autoSizeTextType="uniform"
                            android:backgroundTint="#FFA726"
                            android:gravity="center"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:padding="2dp"
                            android:text="5~6\n(20%)"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />

                        <Button
                            android:id="@+id/diceOverlayRandom"
                            style="@style/Widget.AppCompat.Button"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_marginStart="4dp"
                            android:layout_weight="1"
                            android:autoSizeMaxTextSize="13sp"
                            android:autoSizeMinTextSize="10sp"
                            android:autoSizeTextType="uniform"
                            android:backgroundTint="#AB47BC"
                            android:gravity="center"
                            android:minHeight="0dp"
                            android:minWidth="0dp"
                            android:padding="2dp"
                            android:text="랜덤\n(1/6)"
                            android:textColor="@android:color/white"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <Button
                        android:id="@+id/diceOverlayRollButton"
                        android:layout_width="168dp"
                        android:layout_height="46dp"
                        android:layout_marginTop="10dp"
                        android:backgroundTint="#1976D2"
                        android:includeFontPadding="false"
                        android:minHeight="0dp"
                        android:minWidth="0dp"
                        android:text="굴리기"
                        android:textAllCaps="false"
                        android:textColor="@android:color/white"
                        android:textSize="17sp"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/diceResultContent"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:gravity="center"
                    android:orientation="vertical"
                    android:visibility="gone">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="주사위 결과"
                        android:textColor="#5C6A7D"
                        android:textSize="22sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/diceOverlayResult"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="14dp"
                        android:text="5"
                        android:textColor="#1976D2"
                        android:textSize="76sp"
                        android:textStyle="bold" />
                </LinearLayout>
            </FrameLayout>
        </androidx.cardview.widget.CardView>
    </FrameLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
