<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/board_green"
    android:padding="4dp">

    <androidx.constraintlayout.widget.Guideline android:id="@+id/g_v1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" app:layout_constraintGuide_percent="0.2"/>
    <androidx.constraintlayout.widget.Guideline android:id="@+id/g_v2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" app:layout_constraintGuide_percent="0.4"/>
    <androidx.constraintlayout.widget.Guideline android:id="@+id/g_v3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" app:layout_constraintGuide_percent="0.6"/>
    <androidx.constraintlayout.widget.Guideline android:id="@+id/g_v4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="vertical" app:layout_constraintGuide_percent="0.8"/>

    <androidx.constraintlayout.widget.Guideline android:id="@+id/g_h1" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" app:layout_constraintGuide_percent="0.2"/>
    <androidx.constraintlayout.widget.Guideline android:id="@+id/g_h2" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" app:layout_constraintGuide_percent="0.4"/>
    <androidx.constraintlayout.widget.Guideline android:id="@+id/g_h3" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" app:layout_constraintGuide_percent="0.6"/>
    <androidx.constraintlayout.widget.Guideline android:id="@+id/g_h4" android:layout_width="wrap_content" android:layout_height="wrap_content" android:orientation="horizontal" app:layout_constraintGuide_percent="0.8"/>

    <TextView android:id="@+id/tile0" android:layout_width="0dp" android:layout_height="0dp" android:text="시작" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/g_h1" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="@id/g_v1"/>

    <TextView android:id="@+id/tile1" android:layout_width="0dp" android:layout_height="0dp" android:text="점수(+)" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/g_h1" app:layout_constraintStart_toEndOf="@id/g_v1" app:layout_constraintEnd_toEndOf="@id/g_v2"/>

    <TextView android:id="@+id/tile2" android:layout_width="0dp" android:layout_height="0dp" android:text="카드" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/g_h1" app:layout_constraintStart_toEndOf="@id/g_v2" app:layout_constraintEnd_toEndOf="@id/g_v3"/>

    <TextView android:id="@+id/tile3" android:layout_width="0dp" android:layout_height="0dp" android:text="점수(+)" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/g_h1" app:layout_constraintStart_toEndOf="@id/g_v3" app:layout_constraintEnd_toEndOf="@id/g_v4"/>

    <TextView android:id="@+id/tile4" android:layout_width="0dp" android:layout_height="0dp" android:text="?" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toTopOf="@id/g_h1" app:layout_constraintStart_toEndOf="@id/g_v4" app:layout_constraintEnd_toEndOf="parent"/>

    <TextView android:id="@+id/tile5" android:layout_width="0dp" android:layout_height="0dp" android:text="점수(+)" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/g_h1" app:layout_constraintBottom_toTopOf="@id/g_h2" app:layout_constraintStart_toEndOf="@id/g_v4" app:layout_constraintEnd_toEndOf="parent"/>

    <TextView android:id="@+id/tile6" android:layout_width="0dp" android:layout_height="0dp" android:text="광고" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/g_h2" app:layout_constraintBottom_toTopOf="@id/g_h3" app:layout_constraintStart_toEndOf="@id/g_v4" app:layout_constraintEnd_toEndOf="parent"/>

    <TextView android:id="@+id/tile7" android:layout_width="0dp" android:layout_height="0dp" android:text="점수(-)" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/g_h3" app:layout_constraintBottom_toTopOf="@id/g_h4" app:layout_constraintStart_toEndOf="@id/g_v4" app:layout_constraintEnd_toEndOf="parent"/>

    <TextView android:id="@+id/tile8" android:layout_width="0dp" android:layout_height="0dp" android:text="?" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/g_h4" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toEndOf="@id/g_v4" app:layout_constraintEnd_toEndOf="parent"/>

    <TextView android:id="@+id/tile9" android:layout_width="0dp" android:layout_height="0dp" android:text="점수(-)" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/g_h4" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toEndOf="@id/g_v3" app:layout_constraintEnd_toEndOf="@id/g_v4"/>

    <TextView android:id="@+id/tile10" android:layout_width="0dp" android:layout_height="0dp" android:text="카드" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/g_h4" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toEndOf="@id/g_v2" app:layout_constraintEnd_toEndOf="@id/g_v3"/>

    <TextView android:id="@+id/tile11" android:layout_width="0dp" android:layout_height="0dp" android:text="점수(+)" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/g_h4" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toEndOf="@id/g_v1" app:layout_constraintEnd_toEndOf="@id/g_v2"/>

    <TextView android:id="@+id/tile12" android:layout_width="0dp" android:layout_height="0dp" android:text="?" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/g_h4" app:layout_constraintBottom_toBottomOf="parent" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="@id/g_v1"/>

    <TextView android:id="@+id/tile13" android:layout_width="0dp" android:layout_height="0dp" android:text="점수(-)" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/g_h3" app:layout_constraintBottom_toTopOf="@id/g_h4" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="@id/g_v1"/>

    <TextView android:id="@+id/tile14" android:layout_width="0dp" android:layout_height="0dp" android:text="광고" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/g_h2" app:layout_constraintBottom_toTopOf="@id/g_h3" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="@id/g_v1"/>

    <TextView android:id="@+id/tile15" android:layout_width="0dp" android:layout_height="0dp" android:text="점수(+)" android:background="@drawable/tile_background" android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/g_h1" app:layout_constraintBottom_toTopOf="@id/g_h2" app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="@id/g_v1"/>

    <Button android:id="@+id/btnDice" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="주사위 굴리기"
        app:layout_constraintTop_toTopOf="parent" app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/txtDiceVisual"/>

    <TextView
        android:id="@+id/txtDiceVisual"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_marginBottom="8dp"
        android:background="@drawable/dice_shape"
        android:gravity="center"
        android:text="?"
        android:textColor="#000000"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@+id/btnDice"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <ImageView android:id="@+id/player1" android:layout_width="25dp" android:layout_height="25dp" android:src="@drawable/player_red" android:elevation="10dp"
        app:layout_constraintTop_toTopOf="@id/tile0" app:layout_constraintBottom_toBottomOf="@id/tile0" app:layout_constraintStart_toStartOf="@id/tile0" app:layout_constraintEnd_toEndOf="@id/tile0"
        android:translationX="-8dp" android:translationY="-8dp"/>

    <ImageView android:id="@+id/player2" android:layout_width="25dp" android:layout_height="25dp" android:src="@drawable/player_blue" android:elevation="10dp"
        app:layout_constraintTop_toTopOf="@id/tile0" app:layout_constraintBottom_toBottomOf="@id/tile0" app:layout_constraintStart_toStartOf="@id/tile0" app:layout_constraintEnd_toEndOf="@id/tile0"
        android:translationX="8dp" android:translationY="-8dp"/>

    <ImageView android:id="@+id/player3" android:layout_width="25dp" android:layout_height="25dp" android:src="@drawable/player_green" android:elevation="10dp"
        app:layout_constraintTop_toTopOf="@id/tile0" app:layout_constraintBottom_toBottomOf="@id/tile0" app:layout_constraintStart_toStartOf="@id/tile0" app:layout_constraintEnd_toEndOf="@id/tile0"
        android:translationX="-8dp" android:translationY="8dp"/>

    <ImageView android:id="@+id/player4" android:layout_width="25dp" android:layout_height="25dp" android:src="@drawable/player_yellow" android:elevation="10dp"
        app:layout_constraintTop_toTopOf="@id/tile0" app:layout_constraintBottom_toBottomOf="@id/tile0" app:layout_constraintStart_toStartOf="@id/tile0" app:layout_constraintEnd_toEndOf="@id/tile0"
        android:translationX="8dp" android:translationY="8dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>