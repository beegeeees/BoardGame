<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white"
    android:paddingStart="20dp"
    android:paddingTop="18dp"
    android:paddingEnd="20dp"
    android:paddingBottom="16dp">

    <TextView
        android:id="@+id/miniGameTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/minigame3_title"
        android:textColor="@color/waiting_text_primary"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/miniGameStatusText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:text="@string/minigame3_status_ingame"
        android:textColor="@color/waiting_text_secondary"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/miniGameTitleText" />

    <Button
        android:id="@+id/resetButton"
        android:layout_width="88dp"
        android:layout_height="40dp"
        android:layout_marginTop="8dp"
        android:backgroundTint="@color/title_blue"
        android:text="@string/minigame3_reset"
        android:textAllCaps="false"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/miniGameTitleText" />

    <FrameLayout
        android:id="@+id/mazeContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@id/volumeArea"
        app:layout_constraintDimensionRatio="1:1"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/miniGameStatusText">

        <com.example.adchaosdemo.VolumeMazeView
            android:id="@+id/mazeView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/volumeArea"
        android:layout_width="0dp"
        android:layout_height="110dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="@id/mazeContainer"
        app:layout_constraintStart_toStartOf="@id/mazeContainer">

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/barStartGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.125" />

        <androidx.constraintlayout.widget.Guideline
            android:id="@+id/barEndGuide"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintGuide_percent="0.895" />

        <TextView
            android:id="@+id/volumeIndicatorText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0"
            android:textColor="@color/waiting_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent" />

        <SeekBar
            android:id="@+id/volumeBar"
            android:layout_width="0dp"
            android:layout_height="48dp"
            android:layout_marginTop="34dp"
            android:max="100"
            android:paddingStart="0dp"
            android:paddingEnd="0dp"
            android:progressDrawable="@drawable/bg_volume_progress"
            android:splitTrack="false"
            android:thumb="@drawable/bg_volume_thumb"
            android:thumbOffset="0dp"
            app:layout_constraintEnd_toStartOf="@id/barEndGuide"
            app:layout_constraintStart_toStartOf="@id/barStartGuide"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/volumeMinText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="0"
            android:textColor="@color/waiting_text_secondary"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/barStartGuide"
            app:layout_constraintTop_toBottomOf="@id/volumeBar" />

        <TextView
            android:id="@+id/volumeMaxText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="100"
            android:textColor="@color/waiting_text_secondary"
            android:textSize="14sp"
            app:layout_constraintEnd_toStartOf="@id/barEndGuide"
            app:layout_constraintTop_toBottomOf="@id/volumeBar" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
