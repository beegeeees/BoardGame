<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/title_bg_pastel"
    android:paddingHorizontal="20dp"
    android:paddingVertical="16dp">

    <TextView
        android:id="@+id/optionsTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/options_title"
        android:textColor="@color/title_text_green"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/optionsSplitGuide"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.54" />

    <LinearLayout
        android:id="@+id/leftPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="8dp"
        android:background="@drawable/bg_panel_waiting"
        android:elevation="1dp"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintBottom_toTopOf="@id/closeOptionsButton"
        app:layout_constraintEnd_toStartOf="@id/optionsSplitGuide"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/optionsTitleText">

        <TextView
            android:id="@+id/nicknameTitleText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/options_nickname_title"
            android:textColor="@color/waiting_text_primary"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/nicknameValueText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:gravity="center"
            android:textColor="@color/waiting_text_primary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/changeNicknameButton"
            android:layout_width="180dp"
            android:layout_height="44dp"
            android:layout_marginTop="22dp"
            android:elevation="1dp"
            android:includeFontPadding="false"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:text="@string/options_nickname_change"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="15sp"
            app:backgroundTint="@color/title_blue"
            app:cornerRadius="8dp"
            app:rippleColor="@color/title_blue_pressed" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/rightPanel"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="8dp"
        android:background="@drawable/bg_panel_waiting"
        android:elevation="1dp"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:padding="14dp"
        app:layout_constraintBottom_toTopOf="@id/closeOptionsButton"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@id/optionsSplitGuide"
        app:layout_constraintTop_toBottomOf="@id/optionsTitleText">

        <TextView
            android:id="@+id/serverUrlLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/options_server_url"
            android:textColor="@color/waiting_text_primary"
            android:textSize="15sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/serverUrlInput"
            android:layout_width="match_parent"
            android:layout_height="42dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_panel_waiting"
            android:hint="@string/options_server_url_hint"
            android:inputType="textUri"
            android:paddingHorizontal="10dp"
            android:singleLine="true"
            android:textColor="@color/waiting_text_primary"
            android:textColorHint="@color/waiting_text_secondary"
            android:textSize="13sp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/saveServerUrlButton"
            android:layout_width="130dp"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:elevation="1dp"
            android:includeFontPadding="false"
            android:minHeight="0dp"
            android:minWidth="0dp"
            android:text="@string/options_server_url_save"
            android:textAllCaps="false"
            android:textColor="@android:color/white"
            android:textSize="14sp"
            app:backgroundTint="#64748B"
            app:cornerRadius="8dp"
            app:rippleColor="#475569" />

        <LinearLayout
            android:id="@+id/serverPresetRow"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/useLanServerButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:elevation="1dp"
                android:includeFontPadding="false"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="6dp"
                android:text="@string/options_server_lan"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                app:backgroundTint="#64748B"
                app:cornerRadius="8dp"
                app:rippleColor="#475569" />

            <Space
                android:layout_width="8dp"
                android:layout_height="1dp" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/useWanServerButton"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:elevation="1dp"
                android:includeFontPadding="false"
                android:minHeight="0dp"
                android:minWidth="0dp"
                android:paddingHorizontal="6dp"
                android:text="@string/options_server_wan"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="13sp"
                app:backgroundTint="#64748B"
                app:cornerRadius="8dp"
                app:rippleColor="#475569" />
        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/closeOptionsButton"
        android:layout_width="200dp"
        android:layout_height="44dp"
        android:layout_marginBottom="2dp"
        android:elevation="2dp"
        android:includeFontPadding="false"
        android:minHeight="0dp"
        android:minWidth="0dp"
        android:text="@string/options_close_button"
        android:textAllCaps="false"
        android:textColor="#1E1E1E"
        android:textSize="16sp"
        android:textStyle="bold"
        app:backgroundTint="@color/title_yellow"
        app:cornerRadius="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:rippleColor="@color/title_yellow_pressed" />

</androidx.constraintlayout.widget.ConstraintLayout>
